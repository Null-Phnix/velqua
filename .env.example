# Velqua Configuration
# Copy this file to .env and customize as needed

# Server Settings — localhost only by default (set to 0.0.0.0 for remote access)
VELQUA_HOST=127.0.0.1
VELQUA_PORT=8765
VELQUA_PROXY_PORT=11435

# Auth — set a token to require Bearer auth on API endpoints
# VELQUA_AUTH_TOKEN=your-secret-token-here

# CORS — comma-separated origins (default: localhost only)
# VELQUA_CORS_ORIGINS=http://localhost:8765,http://127.0.0.1:8765

# File Upload Limits
VELQUA_MAX_UPLOAD_MB=100

# Import Limits
VELQUA_MAX_CONVERSATIONS=50
VELQUA_MAX_PROJECTS=20
VELQUA_MAX_MESSAGES=100

# Memory Settings
VELQUA_MEMORY_BUDGET=200

# Paths
VELQUA_DB_PATH=data/velqua.db

# Ollama Integration
VELQUA_OLLAMA_URL=http://localhost:11434

# OpenAI-compatible backend (llama.cpp, vLLM, LocalAI, LM Studio)
VELQUA_OPENAI_BASE_URL=http://localhost:8080

# Logging
VELQUA_LOG_LEVEL=INFO
